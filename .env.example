# ============================================================
#  NexaMart Enterprise SMS — Environment Configuration
#  Copy this file to .env and fill in your values
# ============================================================

# ----- Application -----
APP_NAME="NexaMart"
APP_ENV=development       # development | staging | production
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Africa/Addis_Ababa
APP_DEFAULT_LANG=en       # en | ar | am

# ----- Database (MySQL 8.4) -----
DB_HOST=db
DB_PORT=3306
DB_DATABASE=nexamart_db
DB_USERNAME=nexamart_user
DB_PASSWORD=nexamart_pass_2024
DB_ROOT_PASSWORD=nexamart_root_2024
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# ----- JWT Authentication -----
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING_IN_PRODUCTION
JWT_ACCESS_EXPIRY=900         # 15 minutes (seconds)
JWT_REFRESH_EXPIRY=604800     # 7 days (seconds)
JWT_ALGORITHM=HS256

# ----- CORS -----
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Store-ID,X-Terminal-ID

# ----- Email (SMTP) -----
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=no-reply@nexamart.local
MAIL_FROM_NAME="NexaMart System"
MAIL_ENCRYPTION=null

# ----- File Storage -----
STORAGE_PATH=/var/www/html/backend/storage
MAX_UPLOAD_SIZE_MB=10

# ----- Rate Limiting -----
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=10

# ----- Multi-Store -----
DEFAULT_COMPANY_ID=1
ENABLE_MULTI_STORE=true

# ----- Localization -----
SUPPORTED_LANGUAGES=en,ar,am
DEFAULT_CURRENCY=USD
DEFAULT_TAX_RATE=15.00

# ----- PWA -----
PWA_APP_NAME="NexaMart"
PWA_SHORT_NAME="NexaMart"
PWA_THEME_COLOR=#6366f1
